#Gráfico de sobrevivência dos IRTs
F = ecdf(S1$IRT)
#organiza os IRTs em ordem crescente
x = sort(S1$IRT)
#Função de sobrevivência
S = 1 - F(x)
plot(x, S,
type = "s",
xlab = "IRT (s)",
ylab = "Proporção de IRTs > x",
main = "Função de Sobrevivência dos IRTs",
xlim = c(0,290),
ylim = c(.0075, 1))
